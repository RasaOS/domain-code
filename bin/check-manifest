#!/usr/bin/env bash
#
# bin/check-manifest — verify rasa.json is a complete inventory of the Element.
#
# bin/init and /sync are manifest-driven: they install exactly what
# rasa.json declares. If a file is committed to content/ or seed/ but
# never registered in rasa.json, it silently never ships — and nothing
# else catches it. This script does.
#
# Two checks, both directions:
#   1. Coverage — every git-tracked file under content/ and seed/ is
#      registered in rasa.json (matched by an exact element.files /
#      seed.files 'from', or by an ancestor directory entry).
#   2. Dangling — every rasa.json 'from' points at a path that exists.
#
# Run it before tagging an Element release, or wire it into CI.
#
# Exit: 0 if the manifest is a complete, accurate inventory; 1 otherwise.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
MANIFEST="$REPO_ROOT/rasa.json"

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: bin/check-manifest requires python3." >&2
  exit 1
fi
if [ ! -f "$MANIFEST" ]; then
  echo "ERROR: rasa.json not found at $MANIFEST" >&2
  exit 1
fi
if ! git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERROR: bin/check-manifest must run inside the Element's git repo." >&2
  exit 1
fi

python3 - "$REPO_ROOT" "$MANIFEST" <<'PYEOF'
import json, os, subprocess, sys

repo, manifest_path = sys.argv[1], sys.argv[2]

try:
    manifest = json.load(open(manifest_path))
except (OSError, ValueError) as exc:
    print("ERROR: could not parse rasa.json: %s" % exc)
    sys.exit(1)

# Every 'from' the manifest declares (element-managed + seed), slash-stripped.
froms = []
for section in ("element", "seed"):
    for entry in manifest.get(section, {}).get("files", []):
        froms.append(entry["from"].rstrip("/"))
from_set = set(froms)

# The real inventory: git-tracked files under content/ and seed/.
tracked = subprocess.check_output(
    ["git", "-C", repo, "ls-files", "content", "seed"], text=True
).splitlines()
tracked = [t for t in tracked if t]


def covered(path):
    """True if path equals a 'from', or any ancestor directory is a 'from'."""
    if path in from_set:
        return True
    parts = path.split("/")
    return any("/".join(parts[:i]) in from_set for i in range(1, len(parts)))


uncovered = sorted(p for p in tracked if not covered(p))
dangling = sorted(f for f in froms if not os.path.exists(os.path.join(repo, f)))
problems = len(uncovered) + len(dangling)

print("bin/check-manifest — rasa.json coverage")
print()

if uncovered:
    print("UNREGISTERED — committed under content/ or seed/, absent from rasa.json:")
    for p in uncovered:
        print("  x  %s" % p)
    print()

if dangling:
    print("DANGLING — a rasa.json 'from' points at a path that does not exist:")
    for f in dangling:
        print("  x  %s" % f)
    print()

if problems == 0:
    print("OK   rasa.json is a complete inventory.")
    print("     %d tracked files under content/ + seed/, all registered." % len(tracked))
    sys.exit(0)

print("FAIL %d problem(s) — rasa.json and the Element tree have drifted." % problems)
sys.exit(1)
PYEOF
